{
  "name": "@thib3113/boks-sdk",
  "version": "0.0.14",
  "description": "Core SDK for Boks Parcel Box communication and PIN generation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thib3113/boks-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/thib3113/boks-sdk-js/issues"
  },
  "homepage": "https://thib3113.github.io/boks-sdk-js/",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LEGALS.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0",
  "main": "dist/cjs/boks-sdk.cjs",
  "module": "dist/esm/boks-sdk.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/boks-sdk.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/cjs/boks-sdk.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/types/core.d.ts",
        "default": "./dist/esm/core.js"
      },
      "require": {
        "types": "./dist/types/core.d.cts",
        "default": "./dist/cjs/boks-sdk.cjs"
      }
    },
    "./simulator": {
      "import": {
        "types": "./dist/types/simulator.d.ts",
        "default": "./dist/esm/simulator.js"
      },
      "require": {
        "types": "./dist/types/simulator.d.cts",
        "default": "./dist/cjs/boks-sdk.cjs"
      }
    },
    "./browser": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/boks-sdk.js"
    },
    "./browser-core": {
      "types": "./dist/types/core.d.ts",
      "default": "./dist/boks-core.js"
    },
    "./client": {
      "import": {
        "types": "./dist/types/client.d.ts",
        "default": "./dist/esm/client.js"
      },
      "require": {
        "types": "./dist/types/client.d.cts",
        "default": "./dist/cjs/boks-sdk.cjs"
      }
    },
    "./crypto": {
      "import": {
        "types": "./dist/types/crypto.d.ts",
        "default": "./dist/esm/crypto.js"
      },
      "require": {
        "types": "./dist/types/crypto.d.cts",
        "default": "./dist/cjs/boks-sdk.cjs"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/types/protocol.d.ts",
        "default": "./dist/esm/protocol.js"
      },
      "require": {
        "types": "./dist/types/protocol.d.cts",
        "default": "./dist/cjs/boks-sdk.cjs"
      }
    }
  },
  "unpkg": "dist/boks-sdk.js",
  "jsdelivr": "dist/boks-sdk.js",
  "scripts": {
    "check:exports": "node tests/exports/verify-exports.mjs",
    "check:package": "publint && attw --pack --ignore-rules internal-resolution-error cjs-resolves-to-esm no-resolution",
    "check:all": "pnpm run check:package && pnpm run check:exports",
    "build": "node build.js",
    "docs": "pnpm run docs:build && typedoc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "docs:dev": "vitepress dev wiki",
    "docs:build": "vitepress build wiki"
  },
  "keywords": [
    "boks",
    "smart-lock",
    "parcel-box",
    "ble",
    "sdk"
  ],
  "author": "Thib3113",
  "license": "ISC",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@codecov/bundle-analyzer": "1.9.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@types/node": "24.12.0",
    "@types/web-bluetooth": "0.0.21",
    "@vitest/coverage-v8": "4.1.2",
    "esbuild": "0.27.4",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "fast-check": "4.6.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "typedoc": "0.28.18",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vite-plugin-babel": "1.6.0",
    "vitepress": "1.6.4",
    "vitest": "4.1.2",
    "vue": "3.5.31"
  }
}
